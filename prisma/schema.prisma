// ============================================================
// Garden-BE: Prisma Schema
// Hệ thống hỗ trợ sức khỏe tâm thần qua trồng hoa ảo - thật
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========================
// AUTH SUPPORT
// ========================
model RefreshToken {
  id          Int      @id @default(autoincrement())
  userId      String?  @db.Uuid
  hashedToken String   @unique @db.VarChar(255)
  revoked     Boolean  @default(false)
  expiresAt   DateTime @db.Timestamptz(3)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("RefreshToken")
}

// ========================
// ENUMS
// ========================


enum UserRole {
  USER    // Người dùng app
  FARMER  // Nhà vườn
  ADMIN   // Quản trị viên
}

/// Vòng đời cây từ gieo hạt đến nở hoa
enum PlantStatus {
  SEED        // Hạt giống mới gieo
  SPROUT      // Đang nảy mầm
  GROWING     // Đang sinh trưởng
  BUDDING     // Đang hình thành nụ
  BLOOMING    // Đang nở hoa
  RESTING     // Nghỉ ngơi / không phát triển
  NEEDS_CARE  // Cần chăm sóc khẩn cấp
  COMPLETED   // Hoàn thành vòng đời
}

/// Mức độ cảm xúc của user
enum MoodLevel {
  VERY_BAD  // Rất tệ
  BAD       // Tệ
  NORMAL    // Bình thường
  GOOD      // Tốt
  VERY_GOOD // Rất tốt
}

/// Trạng thái duyệt vườn
enum GardenStatus {
  PENDING   // Chờ admin duyệt
  APPROVED  // Đã được duyệt
  REJECTED  // Bị từ chối
}

/// Loại nhiệm vụ chăm sóc nhỏ hàng ngày
enum CareTaskType {
  WATER_PLANT   // Tưới cây ảo
  BREATHING     // Thở chậm 1 phút
  DRINK_WATER   // Uống một ly nước
  WRITE_JOURNAL // Viết một dòng nhật ký
  LISTEN_SOUND  // Nghe âm thanh thư giãn
  SHORT_WALK    // Đi dạo ngắn
}

/// Loại xác nhận hoàn thành nhiệm vụ
enum VerifyType {
  SELF_CONFIRM   // Tự xác nhận
  TIMER          // Đếm ngược
  OPTIONAL_PHOTO // Ảnh tuỳ chọn
}

/// Tài nguyên thưởng cho cây ảo
enum ResourceType {
  WATER
  SUNLIGHT
  FERTILIZER
  AIR
  LOVE
  DEW
}

// ========================
// NHÓM TÀI KHOẢN
// ========================

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(254)
  passwordHash String   @db.VarChar(255)
  fullName     String?  @db.VarChar(150)
  avatarUrl    String?  @db.VarChar(500)
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)

  // FARMER: quản lý nhiều vườn
  gardens      Garden[]      @relation("FarmerGardens")
  // FARMER: cập nhật ảnh/tình trạng cây thật
  plantUpdates PlantUpdate[] @relation("FarmerPlantUpdates")

  // USER: trồng cây ảo, ghi nhật ký, làm task
  virtualPlants VirtualPlant[]
  moodJournals  MoodJournal[]
  careTaskLogs  CareTaskLog[]
  refreshTokens RefreshToken[]
  devices       UserDevice[]
  notifications Notification[]

  @@map("User")
}

// ========================
// NHÓM NHÀ VƯỜN
// ========================

model Garden {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @db.VarChar(255)
  address        String?      @db.VarChar(500)
  description    String?      @db.Text
  imageUrl       String?      @db.VarChar(500)
  isActive       Boolean      @default(true)
  status         GardenStatus @default(PENDING)   // Chờ duyệt khi farmer tạo
  rejectedReason String?      @db.Text             // Lý do từ chối (admin điền)

  farmerId String @db.Uuid
  farmer   User   @relation("FarmerGardens", fields: [farmerId], references: [id], onDelete: Restrict)

  realPlants RealPlant[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([farmerId])
  @@index([status])
  @@map("Garden")
}

// ========================
// NHÓM HOA / CÂY
// ========================

/// Loại hoa/cây: hoa hướng dương, lavender, sen đá, ...
model FlowerType {
  id              String  @id @default(uuid()) @db.Uuid
  name            String  @unique @db.VarChar(255)
  description     String? @db.Text
  imageUrl        String? @db.VarChar(500) // Ảnh đại diện chung (dùng trong danh sách chọn giống)
  defaultDuration Int?    // Số ngày dự kiến từ gieo đến nở hoa

  /// Ảnh theo từng giai đoạn: { "SEED": "url", "SPROUT": "url", ... }
  stageImages     Json?   // Map<PlantStatus, string>

  /// Số ngày mỗi giai đoạn: { "SEED": 7, "SPROUT": 14, "GROWING": 21, "BUDDING": 14, "BLOOMING": 30 }
  stageDurations  Json?   // Map<PlantStatus, number>

  realPlants    RealPlant[]
  virtualPlants VirtualPlant[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@map("FlowerType")
}

/// Cây thật ngoài vườn của nhà vườn
model RealPlant {
  id   String @id @default(uuid()) @db.Uuid
  code String @unique @db.VarChar(50) // VD: SUNFLOWER-001

  status      PlantStatus @default(SEED)
  isAssigned  Boolean     @default(false) // true khi đã gắn với 1 VirtualPlant
  plantedAt   DateTime?   @db.Date
  completedAt DateTime?   @db.Date

  flowerTypeId String @db.Uuid
  flowerType   FlowerType @relation(fields: [flowerTypeId], references: [id], onDelete: Restrict)

  gardenId String @db.Uuid
  garden   Garden @relation(fields: [gardenId], references: [id], onDelete: Restrict)

  // Mỗi cây thật chỉ gắn được với 1 cây ảo (MVP)
  virtualPlant VirtualPlant?
  updates      PlantUpdate[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([gardenId])
  @@index([flowerTypeId])
  @@index([flowerTypeId, isAssigned, status]) // Index cho query tìm cây còn trống
  @@map("RealPlant")
}

/// Cây ảo của user trong app, gắn 1-1 với cây thật
model VirtualPlant {
  id          String  @id @default(uuid()) @db.Uuid
  nickname    String? @db.VarChar(100) // Tên cây do user đặt

  status      PlantStatus @default(SEED)
  growthPoint Int         @default(0)  // Giữ lại cho streak / thành tích
  streakCount Int         @default(0)  // Chuỗi ngày chăm sóc liên tiếp

  // ── Tài nguyên tích lũy (không reset theo ngày) ─────────────────────────
  waterAmount      Int @default(0)
  sunlightAmount   Int @default(0)
  fertilizerAmount Int @default(0)
  airAmount        Int @default(0)
  loveAmount       Int @default(0)
  dewAmount        Int @default(0)
  lastCaredAt      DateTime? @db.Timestamptz(3) // Lần chăm sóc gần nhất

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  flowerTypeId String     @db.Uuid
  flowerType   FlowerType @relation(fields: [flowerTypeId], references: [id], onDelete: Restrict)

  // @unique: 1 cây thật chỉ thuộc về 1 cây ảo
  realPlantId String    @unique @db.Uuid
  realPlant   RealPlant @relation(fields: [realPlantId], references: [id], onDelete: Restrict)

  careTaskLogs CareTaskLog[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([userId])
  @@index([flowerTypeId])
  @@map("VirtualPlant")
}

/// Nhà vườn cập nhật ảnh/tình trạng cây thật mỗi 2-3 ngày
model PlantUpdate {
  id String @id @default(uuid()) @db.Uuid

  realPlantId String    @db.Uuid
  realPlant   RealPlant @relation(fields: [realPlantId], references: [id], onDelete: Cascade)

  farmerId String @db.Uuid
  farmer   User   @relation("FarmerPlantUpdates", fields: [farmerId], references: [id], onDelete: Restrict)

  imageUrl   String      @db.VarChar(500)
  status     PlantStatus // Trạng thái cây tại thời điểm cập nhật
  note       String?     @db.Text   // Mô tả chung
  healthNote String?     @db.VarChar(500) // Ghi chú tình trạng sức khỏe cây

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([realPlantId, createdAt]) // Timeline query
  @@index([farmerId])
  @@map("PlantUpdate")
}

// ========================
// NHÓM HỖ TRỢ TINH THẦN
// ========================

/// Nhật ký cảm xúc hàng ngày của user
model MoodJournal {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mood MoodLevel
  note String?   @db.Text // Ghi chú cảm xúc

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([userId])
  @@map("MoodJournal")
}

/// Danh sách nhiệm vụ chăm sóc nhỏ (do admin tạo hoặc mặc định)
model CareTask {
  id          String       @id @default(uuid()) @db.Uuid
  title       String       @db.VarChar(255)
  description String?      @db.Text
  type        CareTaskType
  isDefault   Boolean      @default(true)
  isActive    Boolean      @default(true)

  // Mobile gameplay fields
  rewardResource  ResourceType @default(WATER)  // Loại tài nguyên thưởng
  rewardAmount    Int          @default(10)      // Số lượng tài nguyên thưởng
  growthReward    Int          @default(5)       // Điểm phát triển thưởng
  verifyType      VerifyType   @default(SELF_CONFIRM) // Cách xác nhận
  durationSeconds Int?                           // Thời gian đếm ngược (TIMER)

  // Hoạt ảnh nhân vật riêng cho từng task (upload lên Cloudinary)
  characterImageUrl String? @db.VarChar(500)

  logs CareTaskLog[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@map("CareTask")
}

/// Lịch sử user đã hoàn thành task nào trong ngày
model CareTaskLog {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Task có thể gắn hoặc không gắn với cây ảo cụ thể
  virtualPlantId String?       @db.Uuid
  virtualPlant   VirtualPlant? @relation(fields: [virtualPlantId], references: [id], onDelete: SetNull)

  careTaskId String   @db.Uuid
  careTask   CareTask @relation(fields: [careTaskId], references: [id], onDelete: Restrict)

  // taskDate lưu đầu ngày (00:00:00) để dễ check unique theo ngày
  taskDate    DateTime @db.Date
  completedAt DateTime @default(now()) @db.Timestamptz(3)

  // Mỗi user chỉ được hoàn thành 1 task 1 lần mỗi ngày
  @@unique([userId, careTaskId, taskDate])
  @@index([userId])
  @@index([virtualPlantId])
  @@index([careTaskId])
  @@map("CareTaskLog")
}

// ========================
// THIẾT BỊ & THÔNG BÁO
// ========================

/// Lưu FCM token theo từng thiết bị (hỗ trợ multi-device)
model UserDevice {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @db.Uuid
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  fcmToken String  @unique @db.VarChar(500)
  platform String? @db.VarChar(50) // ios | android | web

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([userId])
  @@map("UserDevice")
}

/// Thông báo trong app gửi tới từng user
model Notification {
  id     String  @id @default(uuid()) @db.Uuid
  userId String  @db.Uuid
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  title  String  @db.VarChar(255)
  body   String  @db.Text
  type   String? @db.VarChar(50) // plant_update | task_reminder | system
  isRead Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("Notification")
}
